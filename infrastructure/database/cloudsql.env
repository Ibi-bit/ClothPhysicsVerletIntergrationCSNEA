# Copy this file to cloudsql.env and fill values before running scripts.

# GCP settings
PROJECT_ID=vpnutc
REGION=europe-west2
INSTANCE_NAME=cloth-physics-db

# Database settings
DATABASE_NAME=stick_simulation
DB_USER=dev
DB_PASSWORD=password

# Optional machine tier and version
DB_TIER=db-f1-micro
DB_VERSION=POSTGRES_16
DB_EDITION=ENTERPRISE

# Connection name format: <project>:<region>:<instance>
# Leave blank to auto-calculate in proxy scripts.
INSTANCE_CONNECTION_NAME=

# Local port used by proxy
LOCAL_PORT=5433

# Connection string consumed by app (for local proxy connection)
CLOTH_PHYSICS_DB_CONNECTION="Host=127.0.0.1;Port=5433;Database=stick_simulation;Username=dev;Password=password;SSL Mode=Disable"
